[Unit]
Description=Codex CLI Token Insights Dashboard Service
After=network.target

[Service]
Type=simple
WorkingDirectory=<PROJECT_DIR>
ExecStart=<PROJECT_DIR>/target/release/codex-cli-token-insights
Restart=always
RestartSec=5
Environment=PORT=3001
Environment=RUST_LOG=info

[Install]
WantedBy=default.target
